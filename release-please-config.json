{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-v-in-tag": true,
  "packages": {
    ".": {
      "release-type": "node",
      "extra-files": [
        {
          "type": "json",
          "path": "webos/service/com.biliwebos.app.service/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "webos/meta/appinfo.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "com.biliwebos.app.manifest.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}
