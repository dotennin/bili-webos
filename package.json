{
  "name": "bili-webos-tv",
  "version": "1.3.0",
  "description": "Bilibili client for LG webOS TV",
  "private": true,
  "type": "module",
  "dependencies": {
    "mpegts.js": "^1.8.0",
    "qrcode": "^1.5.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "shaka-player": "^4.12.0",
    "ssh2": "^1.17.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "6.0.2",
    "http-proxy": "1.18.1",
    "react-test-renderer": "19.2.6",
    "vite": "8.0.13"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "package": "vite build && cp -r webos-meta/* dist/ && cd dist && ares-package .",
    "test": "bun test service/com.biliwebos.app.service/test/*.test.js src/**/*.test.mjs",
    "test:coverage": "bun test --preload ./tools/coverage-preload.mjs --coverage --coverage-reporter=text --coverage-reporter=lcov --coverage-dir=coverage",
    "analyze:tv": "bun --env-file=.env tools/debug.mjs",
    "screenshot:tv": "bun --env-file=.env tools/screenshot.mjs"
  },
  "packageManager": "bun@1.3.14"
}
