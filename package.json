{
  "dependencies": {
    "ssh2": "^1.17.0",
    "ws": "^8.20.0"
  },
  "scripts": {
    "dev": "bash -lc 'npm run dev:proxy & npm run dev:app & wait'",
    "dev:app": "npm --prefix app run dev",
    "dev:proxy": "npm --prefix proxy run dev",
    "test": "node --test service/com.biliwebos.app.service/test/*.test.js app/src/**/*.test.mjs",
    "test:coverage": "mkdir -p coverage && node --test --experimental-test-coverage --test-reporter=spec --test-reporter=lcov --test-reporter-destination=stdout --test-reporter-destination=coverage/lcov.info service/com.biliwebos.app.service/test/*.test.js app/src/**/*.test.mjs"
  }
}
