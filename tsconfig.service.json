{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "./webos/service/com.biliwebos.app.service/src",
    "outDir": "./webos/service/com.biliwebos.app.service",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "types": ["node"]
  },
  "include": ["webos/service/com.biliwebos.app.service/src/**/*"],
  "exclude": [
    "node_modules",
    "webos/service/com.biliwebos.app.service/*.js",
    "webos/service/com.biliwebos.app.service/cast/*.js"
  ]
}
